{
  "name": "bounce",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --plugin-search-dir . --write .",
    "lint": "eslint .",
    "check:format": "prettier --plugin-search-dir . --check .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "knip": "knip"
  },
  "lint-staged": {
    "*.{ts,svelte}": [
      "bun run check",
      "bun run lint"
    ],
    "*.{ts,svelte,css,json}": "bun run check:format"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.0.2",
    "lint-staged": "^16.4.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "prettier": "^3.8.1"
  }
}
